{
  "name": "vault-book",
  "version": "1.0.0",
  "description": "Export Obsidian vault to Gitbook-like static site",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
    "build-web": "bun run build-web.ts",
    "build-all": "bun run build-web.ts && tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
    "serve": "bun run server.ts"
  },
  "devDependencies": {
    "@types/node": "^16.11.6",
    "@types/showdown": "^2.0.0",
    "builtin-modules": "3.3.0",
    "esbuild": "0.17.3",
    "obsidian": "latest",
    "tslib": "2.4.0",
    "typescript": "4.7.4"
  },
  "dependencies": {
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "gsap": "^3.15.0",
    "marked": "^18.0.5",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "showdown": "^2.1.0"
  }
}
